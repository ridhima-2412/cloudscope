EC2_MONITORING_ENABLED=true
EC2_DISPLAY_NAME=CloudScope EC2
EC2_REGION=us-east-1
EC2_HOST=54.82.239.35
EC2_PORT=22
EC2_USERNAME=ec2-user

# Local backend runs can use this path directly.
EC2_SSH_KEY_PATH=C:/Users/ridhi/Downloads/cloudscope-key.pem

# Docker backend mounts a read-only key directory and uses this in-container path.
EC2_SSH_KEY_DIR_HOST=C:/Users/ridhi/Downloads
EC2_SSH_KEY_PATH_CONTAINER=/run/secrets/cloudscope-key.pem

# Optional alternative to key auth. Prefer key auth when possible.
EC2_SSH_PASSWORD=

EC2_CONNECT_TIMEOUT=8
EC2_COMMAND_TIMEOUT=10
BACKEND_URL=http://backend:8000
POLL_SECONDS=5
